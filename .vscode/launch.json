{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CDS Watch PG",
      "request": "launch",
      "type": "node",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["cds", "watch", "--profile", "pg"],      
      "console": "integratedTerminal",
      "args": [
        "serve",
        "--with-mocks",
        "--in-memory?"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
