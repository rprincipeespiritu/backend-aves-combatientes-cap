{
  "name": "backend-aves-combatientes",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/postgres": "^2.1.3",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.8.0",
    "@cap-js/sqlite": "^2",
    "sqlite3": "^5.1.7"
  },
  "scripts": {
    "start": "cds-serve",
    "deploy": "cds deploy --profile pg"
  },
  "cds": {
    "requires": {
      "[pg]": {
        "db": {
          "kind": "postgres",
          "impl": "@cap-js/postgres",
          "credentials": {
            "host": "{env:PGHOST}",
            "port": "{env:PGPORT}",
            "database": "{env:PGDATABASE}",
            "user": "{env:PGUSER}",
            "password": "{env:PGPASSWORD}",
            "ssl": true
          }
        }
      },
      "auth": {
        "[production]": {
          "kind": "dummy"
        }
      }
    }
  }
}
